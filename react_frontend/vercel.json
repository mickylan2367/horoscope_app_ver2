{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE_WITH_RENDER_SERVICE.onrender.com/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://REPLACE_WITH_RENDER_SERVICE.onrender.com/media/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
