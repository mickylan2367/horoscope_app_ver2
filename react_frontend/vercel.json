{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://horoscope-app-ver2.onrender.com/api/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "https://horoscope-app-ver2.onrender.com/media/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
