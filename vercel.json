{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd react_frontend && npm ci",
  "buildCommand": "cd react_frontend && npm run build",
  "outputDirectory": "react_frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://horoscope-app-ver2.onrender.com/api/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "https://horoscope-app-ver2.onrender.com/media/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
